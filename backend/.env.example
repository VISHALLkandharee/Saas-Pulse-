# [DATABASE]
# Direct connection to the database (used for Prisma migrations)
DIRECT_URL="postgres://..."
# Connection pooling URL (used by the application for efficiency)
DATABASE_URL="postgres://..."

# [APPLICATION]
PORT=8000
NODE_ENV="production"
CLIENT_URL="https://your-frontend-domain.com"
JWT_SECRET="your-ultra-secure-random-string"
REFRESH_TOKEN_SECRET="your-ultra-secure-random-string-longer"

# [REDIS CACHE]
# Used to speed up the dashboard. You can get a free one at Upstash.
REDIS_URL="redis://default:password@your-redis-host:port"

# [STRIPE]
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# [CLOUDINARY] (Profile Images)
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# [EMAIL PROVIDER]
# If using Resend or SendGrid for the automated alert emails
RESEND_API_KEY="re_..."
